{
  "manifest_version": 3,
  "name": "LeetCode AI Code Quality Analysis",
  "version": "1.0",
  "description": "AI-powered code analysis and suggestions for LeetCode users.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.onrender.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
 "content_scripts": [
  {
    "matches": ["*://leetcode.com/*"],
    "js": ["marked.min.js", "content.js"]
  }
]
,
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["chatbot.svg"],
      "matches": ["*://leetcode.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src https://*.onrender.com http://localhost:5000"
  }
}
